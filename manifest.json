{
  "manifest_version": 3,
  "name": "Workly",
  "version": "1.4.0",
  "description": "Calculate how many hours you need to work to afford any product online.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "language.js",
        "currency.js",
        "parsers/base.js",
        "parsers/trendyol.js",
        "parsers/hepsiburada.js",
        "parsers/amazon.js",
        "parsers/n11.js",
        "parsers/ebay.js",
        "parsers/etsy.js",
        "parsers/generic.js",
        "widget.js",
        "purchase.js",
        "settings-modal.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Workly - Work Hours Calculator"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "dashboard.html",
        "dashboard.css",
        "dashboard.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
